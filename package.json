{
  "name": "express-prisma-mysql",
  "version": "1.0.0",
  "description": "Express.js + Prisma + MySQL API",
  "main": "app.js",
  "scripts": {
    "dev": "nodemon app.js",
    "start": "npx prisma generate && npx prisma migrate deploy && node app.js",
    "postinstall": "npx prisma generate"
  },
  "dependencies": {
    "express": "^4.18.2",
    "@prisma/client": "^6.19.0",
    "@prisma/adapter-mariadb": "^6.19.0",
    "mariadb": "^3.4.0",
    "express-validator": "^7.0.1",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "prisma": "^6.19.0",
    "nodemon": "^3.1.0"
  }
}
